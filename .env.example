# Telegram bot token from @BotFather
BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# Recommended on Railway. If empty, first /start user becomes owner.
OWNER_USER_ID=
ALLOWED_USER_IDS=

# Optional fallback. You can also set Dune API key and Query ID inside Telegram.
DUNE_API_KEY=
DUNE_QUERY_ID=

# Railway PostgreSQL provides DATABASE_URL automatically when added to project.
DATABASE_URL=

MAX_ADDRESSES_PER_JOB=3000
DUNE_TIMEOUT_SECONDS=900
DUNE_POLL_SECONDS=3
JOB_CONCURRENCY=1
